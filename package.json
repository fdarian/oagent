{
	"name": "@oagent/monorepo",
	"version": "0.1.0",
	"private": true,
	"description": "MCP server that exposes OpenCode to Claude Code as a subagent (via ACP)",
	"license": "Apache-2.0",
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*",
		"services/*"
	],
	"scripts": {
		"dev": "bun --filter '*' dev",
		"check": "turbo run check",
		"format": "biome check --write",
		"build": "bun --filter 'oagent' build",
		"ci:version": "changeset version",
		"ci:release": "changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.7",
		"@biomejs/biome": "^2.4.15",
		"turbo": "^2.9.14"
	}
}
