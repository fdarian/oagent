{
	"name": "oagent",
	"version": "0.2.0",
	"type": "module",
	"private": false,
	"description": "MCP server that exposes ACP-compatible coding agents",
	"license": "Apache-2.0",
	"homepage": "https://github.com/fdarian/oagent",
	"repository": {
		"type": "git",
		"url": "https://github.com/fdarian/oagent.git",
		"directory": "apps/cli"
	},
	"engines": {
		"node": ">=18"
	},
	"bin": {
		"oagent": "./bin/oagent.mjs"
	},
	"files": [
		"bin",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "bun scripts/build.ts",
		"build:binaries": "bun scripts/build-binaries.ts",
		"format": "biome check --write",
		"check:type": "tsgo --noEmit",
		"check:lint": "biome check"
	},
	"devDependencies": {
		"@effect/cli": "^0.75.1",
		"@effect/platform": "^0.96.1",
		"@effect/platform-bun": "^0.89.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@oagent/config": "workspace:*",
		"@oagent/engine": "workspace:*",
		"@orpc/client": "^1.14.4",
		"@orpc/server": "^1.14.4",
		"@toon-format/toon": "^2.3.0",
		"@types/bun": "^1.3.13",
		"@typescript/native-preview": "^7.0.0-dev.20260525.1",
		"effect": "^3.21.2",
		"typescript": "^6.0.3"
	}
}
